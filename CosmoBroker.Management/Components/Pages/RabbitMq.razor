@page "/rabbitmq"
@layout MainLayout

<h1>RabbitMQ</h1>
<p class="subtle">RabbitMQ-compatible exchanges and queues surfaced from CosmoBroker's native AMQP layer.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(string.Equals(_statusKind, "ok", StringComparison.OrdinalIgnoreCase) ? "alert-success" : "alert-danger")">
        @_statusMessage
    </div>
}

@if (_rabbitMq == null)
{
    <p><em>Loading RabbitMQ stats...</em></p>
}
else
{
    var selectedSuperStream = GetSelectedSuperStream();

    <div class="stats-grid two">
        <div class="stat-card">
            <span>Exchanges</span>
            <strong>@_rabbitMq.exchanges.Count</strong>
        </div>
        <div class="stat-card">
            <span>Queues</span>
            <strong>@_rabbitMq.queues.Count</strong>
            <small>Streams: @_rabbitMq.queues.Count(x => IsStreamQueue(x))</small>
        </div>
    </div>

    <section class="panel">
        <div class="panel-head">
            <h2>Reset Stream Consumer Offset</h2>
        </div>
        <form method="post" action="/rabbitmq/streams/reset-offset" class="stream-reset-form">
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label" for="stream-vhost">Vhost</label>
                    <input id="stream-vhost" class="form-control" type="text" name="vhost" value="/" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="stream-queue">Queue</label>
                    <input id="stream-queue" class="form-control" type="text" name="queue" placeholder="stream queue" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="stream-consumer">Consumer</label>
                    <input id="stream-consumer" class="form-control" type="text" name="consumer" placeholder="consumer tag" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="stream-offset">Offset</label>
                    <input id="stream-offset" class="form-control" type="text" name="offset" value="first" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Reset</button>
                </div>
            </div>
            <div class="form-text">Use <code>first</code>, <code>last</code>, <code>next</code>, or a numeric offset.</div>
        </form>
    </section>

    <section class="panel">
        <div class="panel-head">
            <h2>Reset Super Stream Consumer Offset</h2>
        </div>
        <form method="post" action="/rabbitmq/super-streams/reset-offset" class="stream-reset-form">
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label" for="super-vhost">Vhost</label>
                    <input id="super-vhost" class="form-control" type="text" name="super-vhost" value="/" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="super-exchange">Exchange</label>
                    <input id="super-exchange" class="form-control" type="text" name="super-exchange" placeholder="super stream exchange" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="super-consumer">Consumer</label>
                    <input id="super-consumer" class="form-control" type="text" name="super-consumer" placeholder="consumer tag" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="super-offset">Offset</label>
                    <input id="super-offset" class="form-control" type="text" name="super-offset" value="first" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Reset All</button>
                </div>
            </div>
            <div class="form-text">Resets the same consumer tag across all partitions of a super stream.</div>
        </form>
    </section>

    <section class="panel">
        <div class="panel-head">
            <h2>Preview Super Stream Route</h2>
        </div>
        <form method="post" action="/rabbitmq/super-streams/route-preview" class="stream-reset-form">
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label" for="route-vhost">Vhost</label>
                    <input id="route-vhost" class="form-control" type="text" name="route-vhost" value="@(selectedSuperStream?.vhost ?? "/")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="route-exchange">Exchange</label>
                    <input id="route-exchange" class="form-control" type="text" name="route-exchange" value="@(selectedSuperStream?.name ?? string.Empty)" placeholder="super stream exchange" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="route-routing-key">Routing Key</label>
                    <input id="route-routing-key" class="form-control" type="text" name="route-routing-key" placeholder="routing key" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="route-partition-key">Partition Key</label>
                    <input id="route-partition-key" class="form-control" type="text" name="route-partition-key" placeholder="optional override" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">Preview</button>
                </div>
            </div>
            <div class="form-text">When provided, partition key overrides routing-key hashing for super-stream partition selection.</div>
        </form>
    </section>

    <section class="panel">
        <div class="panel-head">
            <h2>Update Stream Retention</h2>
        </div>
        <form method="post" action="/rabbitmq/streams/retention" class="stream-reset-form">
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label" for="retention-vhost">Vhost</label>
                    <input id="retention-vhost" class="form-control" type="text" name="retention-vhost" value="/" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="retention-queue">Queue</label>
                    <input id="retention-queue" class="form-control" type="text" name="retention-queue" placeholder="stream queue" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="retention-max-messages">Max Messages</label>
                    <input id="retention-max-messages" class="form-control" type="number" name="retention-max-messages" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="retention-max-bytes">Max Bytes</label>
                    <input id="retention-max-bytes" class="form-control" type="number" name="retention-max-bytes" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="retention-max-age-ms">Max Age (ms)</label>
                    <input id="retention-max-age-ms" class="form-control" type="number" name="retention-max-age-ms" min="0" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">Update</button>
                </div>
            </div>
            <div class="form-text">Leave fields empty to remove that retention limit.</div>
        </form>
    </section>

    <section class="panel">
        <div class="panel-head">
            <h2>Update Super Stream Retention</h2>
        </div>
        <form method="post" action="/rabbitmq/super-streams/retention" class="stream-reset-form">
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label" for="super-retention-vhost">Vhost</label>
                    <input id="super-retention-vhost" class="form-control" type="text" name="super-retention-vhost" value="@(selectedSuperStream?.vhost ?? "/")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="super-retention-exchange">Exchange</label>
                    <input id="super-retention-exchange" class="form-control" type="text" name="super-retention-exchange" value="@(selectedSuperStream?.name ?? string.Empty)" placeholder="super stream exchange" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="super-retention-max-messages">Max Messages</label>
                    <input id="super-retention-max-messages" class="form-control" type="number" name="super-retention-max-messages" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="super-retention-max-bytes">Max Bytes</label>
                    <input id="super-retention-max-bytes" class="form-control" type="number" name="super-retention-max-bytes" min="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="super-retention-max-age-ms">Max Age (ms)</label>
                    <input id="super-retention-max-age-ms" class="form-control" type="number" name="super-retention-max-age-ms" min="0" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">Update</button>
                </div>
            </div>
            <div class="form-text">Applies the limits to every partition of the selected super stream.</div>
        </form>
    </section>

    <div class="panel-grid">
        @if (selectedSuperStream != null)
        {
            <section class="panel">
                <div class="panel-head">
                    <h2>Selected Super Stream</h2>
                    <a href="/rabbitmq">Clear</a>
                </div>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Vhost</th>
                            <th>Name</th>
                            <th>Partitions</th>
                            <th>Messages</th>
                            <th>Bytes</th>
                            <th>Consumers</th>
                            <th>Logical Consumers</th>
                            <th>Max Lag</th>
                            <th>Offsets</th>
                            <th>Retention</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@selectedSuperStream.vhost</td>
                            <td>@selectedSuperStream.name</td>
                            <td>@selectedSuperStream.partition_count</td>
                            <td>@selectedSuperStream.messages</td>
                            <td>@FormatBytes(selectedSuperStream.bytes)</td>
                            <td>@selectedSuperStream.consumers</td>
                            <td>@selectedSuperStream.logical_consumers</td>
                            <td>@selectedSuperStream.max_lag</td>
                            <td>@FormatSuperStreamOffsetRange(selectedSuperStream)</td>
                            <td>@FormatSuperStreamRetention(selectedSuperStream)</td>
                        </tr>
                    </tbody>
                </table>
                @if (selectedSuperStream.consumer_details.Count > 0)
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Consumer</th>
                                <th>Partitions</th>
                                <th>Total Lag</th>
                                <th>Max Lag</th>
                                <th>Next Offsets</th>
                                <th>Partition Detail</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var consumer in selectedSuperStream.consumer_details)
                            {
                                <tr>
                                    <td>@consumer.consumer</td>
                                    <td>@consumer.partition_count</td>
                                    <td>@consumer.total_lag</td>
                                    <td>@consumer.max_lag</td>
                                    <td>@FormatSuperStreamConsumerOffsets(consumer)</td>
                                    <td>@FormatSuperStreamConsumerPartitions(consumer)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Partition</th>
                            <th>Messages</th>
                            <th>Bytes</th>
                            <th>Consumers</th>
                            <th>Offsets</th>
                            <th>Max Lag</th>
                            <th>Retention</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var partition in selectedSuperStream.partition_details)
                        {
                            <tr>
                                <td>@partition.name</td>
                                <td>@partition.messages</td>
                                <td>@FormatBytes(partition.bytes)</td>
                                <td>@partition.consumers</td>
                                <td>@($"{partition.head_offset}..{partition.tail_offset}")</td>
                                <td>@partition.max_lag</td>
                                <td>@FormatPartitionRetention(partition)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        <section class="panel">
            <div class="panel-head">
                <h2>Super Streams</h2>
            </div>
            @if (GetSuperStreamSummaries().Count == 0)
            {
                <p class="subtle">No super streams.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Vhost</th>
                            <th>Name</th>
                            <th>Partitions</th>
                            <th>Messages</th>
                            <th>Bytes</th>
                            <th>Consumers</th>
                            <th>Logical Consumers</th>
                            <th>Max Lag</th>
                            <th>Offset Range</th>
                            <th>Retention</th>
                            <th>Partition Detail</th>
                            <th>Consumer Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stream in GetSuperStreamSummaries())
                        {
                            <tr>
                                <td>@stream.vhost</td>
                                <td><a href="@GetSuperStreamLink(stream)">@stream.name</a></td>
                                <td>@stream.partition_count</td>
                                <td>@stream.messages</td>
                                <td>@FormatBytes(stream.bytes)</td>
                                <td>@stream.consumers</td>
                                <td>@stream.logical_consumers</td>
                                <td>@stream.max_lag</td>
                                <td>@FormatSuperStreamOffsetRange(stream)</td>
                                <td>@FormatSuperStreamRetention(stream)</td>
                                <td>@FormatSuperStreamPartitionDetail(stream)</td>
                                <td>@FormatSuperStreamConsumerDetail(stream)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

        <section class="panel">
            <div class="panel-head">
                <h2>Queues</h2>
            </div>
            @if (_rabbitMq.queues.Count == 0)
            {
                <p class="subtle">No queues.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Vhost</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Messages</th>
                            <th>Bytes</th>
                            <th>Consumers</th>
                            <th>Unacked</th>
                            <th>Durable</th>
                            <th>Offsets</th>
                            <th>Stream Retention</th>
                            <th>Consumer Lag</th>
                            <th>Stream Offsets</th>
                            <th>DLX</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var queue in _rabbitMq.queues.OrderByDescending(x => x.messages))
                        {
                            <tr>
                                <td>@queue.vhost</td>
                                <td>@queue.name</td>
                                <td>@FormatQueueType(queue)</td>
                                <td>@queue.messages</td>
                                <td>@FormatBytes(queue.bytes)</td>
                                <td>@queue.consumers</td>
                                <td>@queue.unacked</td>
                                <td>@(queue.durable ? "yes" : "no")</td>
                                <td>@FormatStreamBounds(queue)</td>
                                <td>@FormatStreamRetention(queue)</td>
                                <td>@FormatStreamLag(queue)</td>
                                <td>@FormatStreamOffsets(queue)</td>
                                <td>@(string.IsNullOrWhiteSpace(queue.dlx) ? "-" : queue.dlx)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

        <section class="panel">
            <div class="panel-head">
                <h2>Exchanges</h2>
            </div>
            @if (_rabbitMq.exchanges.Count == 0)
            {
                <p class="subtle">No exchanges.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Vhost</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Partitions</th>
                            <th>Durable</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exchange in _rabbitMq.exchanges.OrderBy(x => x.vhost).ThenBy(x => x.name))
                        {
                            <tr>
                                <td>@exchange.vhost</td>
                                <td>@exchange.name</td>
                                <td>@exchange.type</td>
                                <td>@FormatExchangePartitions(exchange)</td>
                                <td>@(exchange.durable ? "yes" : "no")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    </div>
}

@code {
    private RabbitMqStats? _rabbitMq;
    private string? _statusKind;
    private string? _statusMessage;

    protected override async ValueTask OnInitializedAsync()
    {
        _statusKind = HttpContext.Request.Query.TryGetValue("status", out var status) ? status : null;
        _statusMessage = HttpContext.Request.Query.TryGetValue("message", out var message) ? message : null;
        var client = HttpContext.RequestServices.GetRequiredService<BrokerMonitorClient>();
        _rabbitMq = await client.GetRabbitMqAsync();
    }

    private static bool IsStreamQueue(RabbitQueueStats queue)
        => string.Equals(queue.queue_type, "stream", StringComparison.OrdinalIgnoreCase);

    private static string FormatQueueType(RabbitQueueStats queue)
        => string.IsNullOrWhiteSpace(queue.queue_type) ? "classic" : queue.queue_type!;

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024L * 1024 * 1024)
            return $"{bytes / (1024d * 1024 * 1024):F2} GB";
        if (bytes >= 1024L * 1024)
            return $"{bytes / (1024d * 1024):F2} MB";
        if (bytes >= 1024L)
            return $"{bytes / 1024d:F2} KB";
        return $"{bytes} B";
    }

    private static string FormatStreamRetention(RabbitQueueStats queue)
    {
        if (!IsStreamQueue(queue))
            return "-";

        var parts = new List<string>();
        if (queue.stream_max_length_messages.HasValue)
            parts.Add($"max-messages {queue.stream_max_length_messages.Value}");
        if (queue.stream_max_length_bytes.HasValue)
            parts.Add($"max-bytes {FormatBytes(queue.stream_max_length_bytes.Value)}");
        if (queue.stream_max_age_ms.HasValue)
            parts.Add($"max-age {TimeSpan.FromMilliseconds(queue.stream_max_age_ms.Value):g}");

        return parts.Count == 0 ? "unbounded" : string.Join(", ", parts);
    }

    private static string FormatStreamBounds(RabbitQueueStats queue)
    {
        if (!IsStreamQueue(queue))
            return "-";

        return $"{queue.stream_head_offset}..{queue.stream_tail_offset}";
    }

    private static string FormatStreamLag(RabbitQueueStats queue)
    {
        if (!IsStreamQueue(queue) || queue.stream_consumer_lag.Count == 0)
            return "-";

        return string.Join(", ", queue.stream_consumer_lag
            .OrderBy(x => x.Key, StringComparer.Ordinal)
            .Select(x => $"{x.Key}:{x.Value}"));
    }

    private static string FormatStreamOffsets(RabbitQueueStats queue)
    {
        if (!IsStreamQueue(queue) || queue.stream_offsets.Count == 0)
            return "-";

        return string.Join(", ", queue.stream_offsets
            .OrderBy(x => x.Key, StringComparer.Ordinal)
            .Select(x => $"{x.Key}:{x.Value}"));
    }

    private static string FormatExchangePartitions(RabbitExchangeStats exchange)
    {
        if (!string.Equals(exchange.type, "SuperStream", StringComparison.OrdinalIgnoreCase) ||
            exchange.super_stream_partitions.Count == 0)
            return "-";

        return string.Join(", ", exchange.super_stream_partitions);
    }

    private List<SuperStreamSummary> GetSuperStreamSummaries()
        => _rabbitMq == null ? [] : BrokerMonitorClient.BuildSuperStreamSummaries(_rabbitMq);

    private SuperStreamSummary? GetSelectedSuperStream()
    {
        if (_rabbitMq == null)
            return null;

        var name = HttpContext.Request.Query.TryGetValue("super", out var superValue) ? superValue : null;
        var vhost = HttpContext.Request.Query.TryGetValue("vhost", out var vhostValue) && !string.IsNullOrWhiteSpace(vhostValue) ? vhostValue : "/";
        return BrokerMonitorClient.FindSuperStream(_rabbitMq, vhost, name);
    }

    private static string GetSuperStreamLink(SuperStreamSummary stream)
        => $"/rabbitmq?super={Uri.EscapeDataString(stream.name)}&vhost={Uri.EscapeDataString(stream.vhost)}";

    private static string FormatSuperStreamPartitionDetail(SuperStreamSummary stream)
    {
        if (stream.partition_details.Count == 0)
            return "-";

        return string.Join(", ", stream.partition_details.Select(p =>
            $"{p.name}:{p.messages} msg,{p.consumers} c,lag {p.max_lag}"));
    }

    private static string FormatSuperStreamConsumerDetail(SuperStreamSummary stream)
    {
        if (stream.consumer_details.Count == 0)
            return "-";

        return string.Join(", ", stream.consumer_details.Select(c =>
            $"{c.consumer}:{c.partition_count} p,lag {c.max_lag}"));
    }

    private static string FormatSuperStreamOffsetRange(SuperStreamSummary stream)
    {
        if (!stream.min_head_offset.HasValue || !stream.max_tail_offset.HasValue)
            return "-";

        return $"{stream.min_head_offset.Value}..{stream.max_tail_offset.Value}";
    }

    private static string FormatSuperStreamRetention(SuperStreamSummary stream)
    {
        if (stream.retention.Count == 0)
            return "unbounded";

        return string.Join(", ", stream.retention);
    }

    private static string FormatPartitionRetention(SuperStreamPartitionSummary partition)
    {
        var parts = new List<string>();
        if (partition.max_length_messages.HasValue)
            parts.Add($"max-messages {partition.max_length_messages.Value}");
        if (partition.max_length_bytes.HasValue)
            parts.Add($"max-bytes {FormatBytes(partition.max_length_bytes.Value)}");
        if (partition.max_age_ms.HasValue)
            parts.Add($"max-age {TimeSpan.FromMilliseconds(partition.max_age_ms.Value):g}");

        return parts.Count == 0 ? "unbounded" : string.Join(", ", parts);
    }

    private static string FormatSuperStreamConsumerOffsets(SuperStreamConsumerSummary consumer)
    {
        if (!consumer.min_next_offset.HasValue || !consumer.max_next_offset.HasValue)
            return "-";

        if (consumer.min_next_offset.Value == consumer.max_next_offset.Value)
            return consumer.min_next_offset.Value.ToString();

        return $"{consumer.min_next_offset.Value}..{consumer.max_next_offset.Value}";
    }

    private static string FormatSuperStreamConsumerPartitions(SuperStreamConsumerSummary consumer)
    {
        if (consumer.partition_details.Count == 0)
            return "-";

        return string.Join(", ", consumer.partition_details.Select(p =>
            $"{p.partition}:next {p.next_offset},lag {p.lag}"));
    }
}
